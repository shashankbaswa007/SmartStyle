rules_version = '2';

// Firebase Storage Security Rules for SmartStyle
service firebase.storage {
  match /b/{bucket}/o {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check file size (max 10MB — stricter than Firestore 20MB default)
    function isValidSize() {
      return request.resource.size < 10 * 1024 * 1024;
    }
    
    // Check if file is a safe image type (JPEG, PNG, WebP, GIF only)
    function isSafeImage() {
      return request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }
    
    // ============================================
    // USER UPLOADS — private, owner-only access
    // ============================================
    match /users/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() 
                   && request.auth.uid == userId 
                   && isSafeImage() 
                   && isValidSize();
    }
    
    // ============================================
    // OUTFIT IMAGES — authenticated read (not fully public)
    // ============================================
    match /outfits/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() 
                   && request.auth.uid == userId 
                   && isSafeImage() 
                   && isValidSize();
    }
    
    // ============================================
    // RECOMMENDATION IMAGES — authenticated read
    // ============================================
    match /recommendations/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() 
                   && request.auth.uid == userId 
                   && isSafeImage() 
                   && isValidSize();
    }
    
    // ============================================
    // TEMPORARY UPLOADS — private, auto-deleted by Cloud Functions
    // ============================================
    match /temp/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() 
                   && request.auth.uid == userId 
                   && isSafeImage() 
                   && isValidSize();
    }
    
    // ============================================
    // WARDROBE IMAGES — private, owner-only access
    // ============================================
    match /wardrobe/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() 
                   && request.auth.uid == userId 
                   && isSafeImage() 
                   && isValidSize();
    }
    
    // ============================================
    // GENERATED IMAGES CACHE — authenticated read, auth + validation for write
    // ============================================
    match /generated-images/{imageHash} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
                   && isSafeImage()
                   && isValidSize();
    }
    
    // ============================================
    // DEFAULT DENY — catch-all for any unmatched paths
    // ============================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
