# ========================================
# SmartStyle Environment Variables Template
# ========================================
# Copy this file to .env.local and fill in your actual values
# $ cp .env.example .env.local

# ========================================
# GROQ API (PRIMARY - 14,400/day FREE!) ⚡
# ========================================
# Get FREE API key from: https://console.groq.com/keys
# Free tier: 14,400 requests/day (no credit card required!)
GROQ_API_KEY=your_groq_api_key_here

# ========================================
# Google Generative AI (BACKUP)
# ========================================
# Get from: https://aistudio.google.com/app/apikey
# Free tier: 50 requests/day per key
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here
GOOGLE_GENAI_API_KEY_BACKUP=your_backup_google_genai_api_key_here

# ========================================
# OpenWeather API (Optional)
# ========================================
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ========================================
# Firebase Configuration (REQUIRED)
# ========================================
# Get from Firebase Console → Project Settings → Your apps
# These are public and safe to expose (security via Firestore rules)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# ========================================
# Tavily API (Optional - E-commerce links)
# ========================================
# Get from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ========================================
# Redis Cache (Optional - server caching/rate-limit durability)
# ========================================
# Get from: https://upstash.com/
UPSTASH_REDIS_REST_URL=your_upstash_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# ========================================
# Pollinations.ai (PRIMARY - Image Generation)
# ========================================
# Get from: https://enter.pollinations.ai/
# Secret keys (sk_) for server-side, no rate limits
# Uses gen.pollinations.ai unified API with FLUX model
POLLINATIONS_API_KEY=your_pollinations_secret_key_here

# ========================================
# Replicate (Optional - Premium Image Fallback)
# ========================================
# Get from: https://replicate.com/account/api-tokens
# ~$0.003 per image, excellent quality
REPLICATE_API_TOKEN=your_replicate_api_token_here

# ========================================
# Together.ai (Optional - Free Image Fallback)
# ========================================
# Get from: https://api.together.xyz
# Free tier: ~60 image generations per day
TOGETHER_API_KEY=your_together_api_key_here

# ========================================
# HuggingFace API (Optional)
# ========================================
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ========================================
# Firebase Admin (Server-side only)
# ========================================
# For server-side operations - NEVER commit this value
# Generate from Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Alternative to FIREBASE_SERVICE_ACCOUNT_KEY:
# absolute path to a local service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional local emulator host (for Firebase Auth emulator only).
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Runtime log level (debug | info | warn | error). Defaults by environment if unset.
LOG_LEVEL=info

# ========================================
# Session/Auth Cookie Settings (Optional)
# ========================================
# Set for production custom domains to scope secure cookies correctly.
NEXT_PUBLIC_COOKIE_DOMAIN=.yourdomain.com

# ========================================
# Alerts and Metrics Webhooks (Optional)
# ========================================
# UX alert webhook target used by /api/ux-alert.
UX_ALERT_WEBHOOK_URL=https://example.com/webhook

# Functions scheduled metrics snapshot integration.
RECOMMEND_METRICS_SNAPSHOT_URL=https://your-app-domain/api/recommend/metrics/snapshot
RECOMMEND_METRICS_SNAPSHOT_SECRET=your_metrics_snapshot_secret_here

# ========================================
# Feature Flags / Testing Switches (Optional)
# ========================================
# Enables Gemini-based analysis flow when true.
SMARTSTYLE_USE_GEMINI=false

# Rollout toggles for premium loading visuals (1=enabled, 0=disabled).
NEXT_PUBLIC_STYLE_CHECK_PREMIUM_LOADER=1
NEXT_PUBLIC_AUTH_PREMIUM_LOADER=1

# E2E auth bypass for automation only.
E2E_AUTH_BYPASS=0
NEXT_PUBLIC_E2E_AUTH_BYPASS=false
# In production builds, bypass is honored only on localhost/127.0.0.1.

# Dev auth fallback (unverified token payload parsing) for local debug only.
# Keep disabled in production/staging.
ALLOW_DEV_AUTH_FALLBACK=0

# Optional admin UID allowlist for /api/admin/* endpoints.
# Prefer Firebase custom claims (admin=true) and keep allowlist empty in production.
ADMIN_USER_IDS=

# ========================================
# SETUP INSTRUCTIONS
# ========================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your actual API keys above
# 3. NEVER commit .env or .env.local to git
# 4. See README.md or docs/ for detailed setup instructions

# Notes:
# - NODE_ENV is set by Next.js/runtime and usually should not be manually defined.
# - K_SERVICE, FUNCTION_TARGET, GAE_ENV, GCLOUD_PROJECT, GOOGLE_CLOUD_PROJECT are
#   platform-provided in deployed environments and are not required in local .env files.

# ========================================
# Local optional features
# Enable local color extraction fallback (set to 'true' to enable). Requires installing node-vibrant.
ENABLE_LOCAL_COLOR_FALLBACK=false
