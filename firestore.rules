rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns the resource (path-based ownership)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Validate that a string field is present and non-empty
    function isNonEmptyString(field) {
      return field is string && field.size() > 0;
    }
    
    // Validate document size limit (1MB Firestore limit, enforce 500KB for safety)
    function isReasonableSize() {
      return request.resource.size() < 512 * 1024;
    }
    
    // Validate that the incoming document has a userId matching the authenticated user
    function hasValidUserId() {
      return request.resource.data.userId == request.auth.uid;
    }
    
    // ============================================
    // USER PREFERENCES (top-level, keyed by userId)
    // ============================================
    match /userPreferences/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isReasonableSize();
      allow update: if isOwner(userId) && isReasonableSize();
      // Allow delete for GDPR/account cleanup
      allow delete: if isOwner(userId);
    }
    
    // ============================================
    // USER INTERACTIONS (top-level, keyed by userId)
    // ============================================
    match /userInteractions/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isReasonableSize();
      allow update: if isOwner(userId) && isReasonableSize();
      allow delete: if false; // Interaction data is append-only
      
      // Interaction sessions (nested under userInteractions)
      match /sessions/{sessionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isReasonableSize();
        allow update: if isOwner(userId) && isReasonableSize();
        allow delete: if false; // Sessions are immutable once created
      }
    }

    // ============================================
    // ANTI-REPETITION CACHE (top-level, keyed by userId)
    // ============================================
    match /antiRepetitionCache/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isReasonableSize();
      allow update: if isOwner(userId) && isReasonableSize();
      allow delete: if false; // Cache managed by system
    }

    // ============================================
    // EXPLORATION METRICS (top-level, keyed by userId)
    // ============================================
    match /explorationMetrics/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isReasonableSize();
      allow update: if isOwner(userId) && isReasonableSize();
      allow delete: if false; // Metrics are append-only
    }
    
    // ============================================
    // USER SUB-COLLECTIONS (outside /users/{userId} match for clarity)
    // ============================================
    
    // Comprehensive Preferences (preference engine nested collections)
    match /users/{userId}/preferences/{subcollection}/{docId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isReasonableSize();
      allow update: if isOwner(userId) && isReasonableSize();
      allow delete: if isOwner(userId);
    }
    
    // User interactions tracking (colors, styles, shopping)
    match /users/{userId}/interactions/{interactionType} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isReasonableSize();
      allow update: if isOwner(userId) && isReasonableSize();
      allow delete: if false; // Interaction records are immutable
    }
    
    // Blocklists (hard, soft, temporary)
    match /users/{userId}/blocklists/{blocklistType} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isReasonableSize();
      allow update: if isOwner(userId) && isReasonableSize();
      allow delete: if isOwner(userId); // Users can clear blocklists
    }
    
    // ============================================
    // RECOMMENDATION HISTORY (top-level, owns userId field)
    // ============================================
    match /recommendationHistory/{recommendationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && hasValidUserId() && isReasonableSize();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid; // Cannot reassign userId
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // ============================================
    // USERS COLLECTION & NESTED SUB-COLLECTIONS
    // ============================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isReasonableSize();
      allow update: if isOwner(userId) && isReasonableSize();
      // Allow delete for GDPR/account cleanup
      allow delete: if isOwner(userId);
      
      // Recommendation history (nested)
      match /recommendationHistory/{recommendationId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isReasonableSize();
        allow update: if isOwner(userId) && isReasonableSize();
        allow delete: if isOwner(userId);
      }
      
      // Feedback on recommendations (nested)
      match /feedback/{recommendationId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isReasonableSize();
        allow update: if isOwner(userId) && isReasonableSize();
        allow delete: if false; // Feedback is immutable for data integrity
      }
      
      // Outfit usage tracking (nested)
      match /outfitUsage/{usageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isReasonableSize();
        allow update: if isOwner(userId) && isReasonableSize();
        allow delete: if false; // Usage history is immutable
      }
      
      // Liked outfits (nested) — with data validation
      match /likedOutfits/{outfitId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) 
                      && isReasonableSize()
                      && isNonEmptyString(request.resource.data.title)
                      && isNonEmptyString(request.resource.data.imageUrl);
        allow update: if isOwner(userId) && isReasonableSize();
        allow delete: if isOwner(userId);
      }
      
      // Wardrobe items (nested) — with data validation
      match /wardrobeItems/{itemId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) 
                      && isReasonableSize()
                      && isNonEmptyString(request.resource.data.imageUrl)
                      && isNonEmptyString(request.resource.data.itemType)
                      && request.resource.data.itemType in ['top', 'bottom', 'dress', 'shoes', 'accessory', 'outerwear'];
        allow update: if isOwner(userId) && isReasonableSize();
        allow delete: if isOwner(userId);
      }
      
      // Saved wardrobe outfit combinations (nested)
      match /wardrobeOutfits/{outfitId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isReasonableSize();
        allow update: if isOwner(userId) && isReasonableSize();
        allow delete: if isOwner(userId);
      }
      
      // Saved color palettes (nested)
      match /colorPalettes/{paletteId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) 
                      && isReasonableSize()
                      && isNonEmptyString(request.resource.data.harmonyType);
        allow update: if isOwner(userId) && isReasonableSize();
        allow delete: if isOwner(userId);
      }
    }
    
    // ============================================
    // SYSTEM & AUDIT COLLECTIONS
    // ============================================
    
    // System Logs — authenticated create only, no read/update/delete
    match /systemLogs/{logId} {
      allow create: if isAuthenticated() && isReasonableSize();
      allow read, update, delete: if false;
    }
    
    // Audit Logs — immutable records, users can read their own
    match /auditLogs/{logId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() 
                    && hasValidUserId() 
                    && isReasonableSize();
      allow update, delete: if false; // Audit logs are immutable
    }
    
    // User Preferences History — immutable change records
    match /userPreferencesHistory/{historyId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() 
                    && hasValidUserId() 
                    && isReasonableSize();
      allow update, delete: if false; // History is immutable
    }
    
    // Deleted Items — for data recovery, immutable once created
    match /deletedItems/{deletionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() 
                    && hasValidUserId() 
                    && isReasonableSize();
      // Allow limited update for recovery marking (canRecover, recoveredAt)
      allow update: if isAuthenticated() 
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid; // Cannot reassign userId
      allow delete: if false; // Deletion records are permanent
    }
    
    // Cleanup Jobs — read-only for clients, write-only for Cloud Functions
    match /cleanupJobs/{jobId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }
    
    // API Cache — read-only for clients; writes only via server/admin SDK
    match /apiCache/{cacheKey} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }
    
    // Rate Limits — scoped to own userId, no delete to prevent counter manipulation
    match /rateLimits/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isReasonableSize();
      allow update: if isOwner(userId) && isReasonableSize();
      allow delete: if false; // Prevent counter manipulation
    }
    
    // ============================================
    // ARCHIVE COLLECTIONS — admin/Cloud Functions only
    // ============================================
    match /auditLogsArchive/{logId} {
      allow read, write: if false;
    }
    
    match /recommendationHistoryArchive/{recId} {
      allow read, write: if false;
    }
    
    match /deletedItemsArchive/{deletionId} {
      allow read, write: if false;
    }
    
    // ============================================
    // DEFAULT DENY — catch-all for any unmatched paths
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
